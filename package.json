{
  "name": "jublia-dex",
  "version": "1.0.0",
  "author": "Jeffry",
  "homepage": "https://alxjeff182.github.io/jublia-pokedex/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 8100",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "prebuild": "node scripts/generate-sitemap.mjs",
    "build": "ng build",
    "postbuild": "node scripts/copy-404.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --configuration=ci --no-watch --browsers=ChromeHeadless",
    "e2e": "playwright test e2e/smoke.spec.ts",
    "e2e:visual": "playwright test e2e/visual.spec.ts",
    "e2e:screenshots": "playwright test e2e/submission-screenshots.spec.ts",
    "e2e:ui": "playwright test --ui",
    "analyze": "ng build --configuration=development && source-map-explorer www/main.js www/vendor.js --html analyze-report.html",
    "lint": "ng lint",
    "ionic:serve": "ng serve --port 8100",
    "ionic:build": "ng build",
    "cap:sync": "ng build && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android"
  },
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@angular/animations": "22.0.6",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/platform-browser-dynamic": "22.0.6",
    "@angular/router": "22.0.6",
    "@angular/service-worker": "^22.0.6",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@ionic/angular": "^8.0.0",
    "ionicons": "^7.0.0",
    "lottie-web": "^5.13.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "22.0.6",
    "@angular-eslint/builder": "22.1.0",
    "@angular-eslint/eslint-plugin": "22.1.0",
    "@angular-eslint/eslint-plugin-template": "22.1.0",
    "@angular-eslint/schematics": "22.1.0",
    "@angular-eslint/template-parser": "22.1.0",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@angular/language-service": "22.0.6",
    "@axe-core/playwright": "^4.10.2",
    "@capacitor/cli": "8.4.1",
    "@ionic/angular-toolkit": "^12.0.0",
    "@playwright/test": "^1.52.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.0"
  },
  "description": "Premium Pokédex app — Angular, Ionic, Capacitor, PokéAPI"
}
